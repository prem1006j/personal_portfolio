<%- include("../includes/head", { title: project.projectName }) %>

<%- include("../includes/navbar") %>

<h1><%= project.projectName %></h1>

<img src="<%= project.image %>" alt="<%= project.projectName %>" width="400">

<p><%= project.description %></p>

<h3>Category</h3>
<p><%= project.category %></p>

<h3>Technologies</h3>

<ul>
<% for(let tech of project.technologies) { %>
    <li><%= tech %></li>
<% } %>
</ul>

<% if(project.githubLink){ %>
    <a href="<%= project.githubLink %>" target="_blank">GitHub</a>
<% } %>

<br><br>

<% if(project.liveLink){ %>
    <a href="<%= project.liveLink %>" target="_blank">Live Demo</a>
<% } else { %>
    <p>Coming Soon</p>
<% } %>

<br><br>

<a href="/">⬅ Back</a>

<%- include("../includes/footer") %>