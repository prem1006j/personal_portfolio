<section id="hero" class="py-5" data-aos="fade-up">

    <div class="container">

        <div class="row align-items-center min-vh-75">

            <!-- Profile Image -->
            <div class="col-lg-5 text-center mb-4 mb-lg-0">

                <img 
                src="<%= profile.image %>"
                class="img-fluid hero-img"
                alt="<%= profile.name %>">

            </div>


            <!-- Hero Content -->
            <div class="col-lg-7">

                <p class="text-primary fw-bold fs-5">
                    Hello, I'm
                </p>


                <h1 class="display-3 fw-bold">
                    <%= profile.name %>
                </h1>


                <h2 class="text-secondary mb-3">
                    <%= profile.title %>
                </h2>


                <p class="lead">
                    <%= profile.bio %>
                </p>


                <p class="fs-5">
                    📍 <%= profile.location %>
                </p>



                <div class="mt-4">


                    <a 
                    href="<%= profile.resume %>"
                    target="_blank"
                    class="btn btn-primary btn-lg me-2">

                        <i class="bi bi-file-earmark-text"></i>
                        Resume

                    </a>



                    <a 
                    href="https://github.com/prem1006j"
                    target="_blank"
                    class="btn btn-dark btn-lg me-2">

                        <i class="bi bi-github"></i>
                        GitHub

                    </a>



                    <a 
                    href="https://www.linkedin.com/in/YOUR-LINKEDIN/"
                    target="_blank"
                    class="btn btn-info text-white btn-lg">

                        <i class="bi bi-linkedin"></i>
                        LinkedIn

                    </a>


                </div>


            </div>


        </div>

    </div>


</section>