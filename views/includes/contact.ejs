    <!-- Contact -->

    <section id="contact" class="py-5">

    <div class="container">

        <h2 class="text-center mb-5">Contact Me</h2>

        <div class="row justify-content-center">

            <div class="col-md-8">

                <form action="/contact" method="POST">

                    <div class="mb-3">

                        <label>Name</label>

                        <input
                            type="text"
                            name="name"
                            class="form-control"
                            required>

                    </div>

                    <div class="mb-3">

                        <label>Email</label>

                        <input
                            type="email"
                            name="email"
                            class="form-control"
                            required>

                    </div>

                    <div class="mb-3">

                        <label>Subject</label>

                        <input
                            type="text"
                            name="subject"
                            class="form-control">

                    </div>

                    <div class="mb-3">

                        <label>Message</label>

                        <textarea
                            name="message"
                            rows="5"
                            class="form-control"
                            required></textarea>

                    </div>

                    <button class="btn btn-primary">

                        Send Message

                    </button>

                </form>

            </div>

        </div>

    </div>

</section>

</div>